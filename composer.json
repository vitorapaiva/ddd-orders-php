{
    "name": "tcc/ddd-orders-php",
    "description": "Serviço de Pedidos implementado em PHP com DDD e Arquitetura Hexagonal",
    "type": "project",
    "require": {
        "php": "^8.5",
        "monolog/monolog": "^3.5",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "guzzlehttp/guzzle": "^7.8",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpmetrics/phpmetrics": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "Orders\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Orders\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:3000 -t public",
        "test": "phpunit",
        "metrics": [
            "phpunit",
            "phpmetrics --report-html=./phpmetrics-report --junit=build/phpunit-junit.xml src/"
        ]
    }
}
